# SSH private keys
*.pem

# Terraform secrets and generated state
terraform/voteball.tfvars
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/.terraform.tfstate.lock.info
terraform/.terraform/
terraform/snapshot.auto.tfvars

# Ansible: secrets.yml is committed ENCRYPTED via ansible-vault — only the
# vault password itself and the generated (non-secret) inventory stay out of git.
ansible-project/.vault_pass
ansible-project/inventories/voteball/hosts
ansible-project/inventories/voteball/group_vars/all/main.yml

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
