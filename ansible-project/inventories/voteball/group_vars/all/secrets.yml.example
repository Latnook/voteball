# Copy this file to secrets.yml, fill in real values, then encrypt it with
# ansible-vault before committing — never commit plaintext secrets.
#
#   cd ansible-project
#   openssl rand -hex 32 > .vault_pass        # one-time: generate a vault password (gitignored, never commit)
#   cp inventories/voteball/group_vars/all/secrets.yml.example \
#      inventories/voteball/group_vars/all/secrets.yml
#   # edit secrets.yml: set db_pass (matches terraform/voteball.tfvars) and admin_secret
#   ansible-vault encrypt inventories/voteball/group_vars/all/secrets.yml --vault-password-file .vault_pass
#
# ansible.cfg already points at .vault_pass via vault_password_file, so
# ansible-playbook / ansible-vault view/edit work transparently once it exists.
# To edit the encrypted file later: ansible-vault edit inventories/voteball/group_vars/all/secrets.yml
db_pass: your_rds_master_password_here
admin_secret: your_admin_secret_here
