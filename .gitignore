# SSH keys
*.pem
*.pub

# Reference PDFs (course material etc.) — not part of the codebase
*.pdf

# Leftovers from the retired k3s stack: the directory is gone from the repo, but a local
# terraform/ may still hold .terraform provider binaries (~800MB) and an empty state file.
# Ignored so `git add -A` can never sweep them back in.
terraform/

# Terraform: your own settings and all generated state.
# NOTE: terraform.tfstate* (glob) also covers the timestamped backups Terraform writes
# (terraform.tfstate.1784477786.backup), which a bare ".backup" pattern misses.
terraform-eks/voteball-eks.tfvars
terraform-eks/terraform.tfstate*
terraform-eks/.terraform.tfstate.lock.info
terraform-eks/tfplan
terraform-eks/.terraform/
# Written by scripts/find-latest-snapshot.sh before each apply; machine-specific, never committed.
terraform-eks/snapshot.auto.tfvars

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Local agent/session state — never belongs in the repo.
.superpowers/
.remember/
.claude/settings.local.json

# Personal notes (not part of the submission)
EXPLAINER.md
PROJECT-QA.md
